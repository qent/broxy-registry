{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/chroma-mcp",
  "title": "ChromaDB",
  "description": "Vector database for embeddings storage, similarity search, and retrieval workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/chroma-core/chroma-mcp",
  "repository": {
    "source": "github",
    "url": "https://github.com/chroma-core/chroma-mcp"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/chroma-mcp.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "packages": [
    {
      "environmentVariables": [
        {
          "default": "http://localhost:8000",
          "description": "ChromaDB server URL",
          "name": "CHROMA_SERVER_URL"
        },
        {
          "description": "API key for ChromaDB authentication",
          "isSecret": true,
          "name": "CHROMA_API_KEY"
        }
      ],
      "identifier": "ghcr.io/stacklok/dockyard/uvx/chroma-mcp:0.2.6",
      "registryType": "oci",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
