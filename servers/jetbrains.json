{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/jetbrains",
  "title": "JetBrains",
  "description": "Connect to JetBrains IDEs (IntelliJ IDEA, WebStorm, PyCharm, GoLand, and others).",
  "version": "2026.1",
  "websiteUrl": "https://www.jetbrains.com/help/idea/mcp-server.html",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/jetbrains.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "sse",
      "url": "http://localhost:64343/sse",
      "headers": [
        {
          "name": "IJ_MCP_SERVER_PROJECT_PATH",
          "description": "Absolute path to the project opened in a JetBrains IDE.",
          "value": "{project_path}",
          "isRequired": true,
          "isSecret": false,
          "variables": {
            "project_path": {
              "description": "Absolute project path for JetBrains MCP context.",
              "format": "filepath",
              "placeholder": "/Users/you/Repos/project",
              "isRequired": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools",
        "resources"
      ]
    }
  }
}
