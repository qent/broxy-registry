{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/huggingface",
  "title": "Hugging Face",
  "description": "Hugging Face MCP server for searching Hub models, datasets, Spaces, papers, and documentation.",
  "version": "latest",
  "websiteUrl": "https://huggingface.co/docs/hub/agents-mcp",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/huggingface.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://huggingface.co/mcp",
      "oauth": {
        "type": "oauth",
        "allowDynamicRegistration": true
      }
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
