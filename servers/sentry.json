{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/sentry",
  "title": "Sentry",
  "description": "Application monitoring platform for error tracking, performance insights, and issue triage.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/getsentry/sentry-mcp",
  "repository": {
    "source": "github",
    "url": "https://github.com/getsentry/sentry-mcp"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/sentry.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "packages": [
    {
      "environmentVariables": [
        {
          "description": "Sentry user auth token with necessary scopes",
          "isRequired": true,
          "isSecret": true,
          "name": "SENTRY_ACCESS_TOKEN"
        },
        {
          "description": "Sentry host URL (e.g., sentry.example.com)",
          "name": "SENTRY_HOST"
        },
        {
          "description": "OpenAI API key for AI-powered search tools (search_events, search_issues)",
          "isSecret": true,
          "name": "OPENAI_API_KEY"
        }
      ],
      "identifier": "ghcr.io/stacklok/dockyard/npx/sentry-mcp-server:0.29.0",
      "registryType": "oci",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
