{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/brave",
  "title": "Brave Search",
  "description": "Private web search to find fresh information, websites, and local results quickly.",
  "version": "0.6.2",
  "websiteUrl": "https://brave.com/search/api/",
  "repository": {
    "source": "github",
    "url": "https://github.com/modelcontextprotocol/servers-archived",
    "subfolder": "src/brave-search"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/brave.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "packages": [
    {
      "registryType": "oci",
      "identifier": "docker.io/mcp/brave-search",
      "version": "0.6.2",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "-i"
        },
        {
          "type": "positional",
          "value": "--rm"
        },
        {
          "type": "positional",
          "value": "-e"
        },
        {
          "type": "positional",
          "value": "BRAVE_API_KEY"
        }
      ],
      "environmentVariables": [
        {
          "name": "BRAVE_API_KEY",
          "description": "Brave Search API key.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
