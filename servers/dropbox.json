{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/dropbox",
  "title": "Dropbox Dash MCP Server",
  "description": "Official Dropbox Dash remote MCP endpoint.",
  "version": "latest",
  "websiteUrl": "https://help.dropbox.com/integrations/set-up-MCP-server",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/dropbox.png",
      "mimeType": "image/png",
      "sizes": [
        "64x64"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.dropbox.com/dash",
      "headers": [
        {
          "name": "Authorization",
          "description": "Optional bearer token for clients without OAuth flow.",
          "value": "Bearer {dropbox_dash_token}",
          "isRequired": false,
          "isSecret": true,
          "variables": {
            "dropbox_dash_token": {
              "description": "Dropbox Dash access token.",
              "isRequired": false,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
