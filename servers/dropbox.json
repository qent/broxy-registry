{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/dropbox",
  "title": "Dropbox",
  "description": "Cloud file storage and collaboration for syncing, sharing, and organizing team content.",
  "version": "latest",
  "websiteUrl": "https://help.dropbox.com/integrations/set-up-MCP-server",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/dropbox.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.dropbox.com/dash"
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
