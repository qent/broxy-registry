{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/redis",
  "title": "Redis",
  "description": "In-memory data platform for caching, key-value operations, and real-time application state.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/redis/mcp-redis",
  "repository": {
    "source": "github",
    "url": "https://github.com/redis/mcp-redis"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/redis.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "redis-mcp-server@latest",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "--from"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "redis-mcp-server"
        },
        {
          "type": "named",
          "name": "--url",
          "valueHint": "redis_url",
          "description": "Redis connection URL.",
          "placeholder": "redis://localhost:6379/0",
          "isRequired": true
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
