{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/notion",
  "title": "Notion",
  "description": "Connected workspace for docs, knowledge bases, project plans, and team collaboration.",
  "version": "latest",
  "websiteUrl": "https://developers.notion.com/guides/mcp/get-started-with-mcp",
  "repository": {
    "source": "github",
    "url": "https://github.com/makenotion/notion-mcp-server"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/notion.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.notion.com/mcp"
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools",
        "resources",
        "prompts"
      ]
    }
  }
}
