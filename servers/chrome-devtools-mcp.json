{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "description": "Live Chrome debugging and inspection via DevTools for performance, network, and DOM analysis.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ],
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/chrome-devtools-mcp.png"
    }
  ],
  "name": "io.qent.broxy/chrome-devtools-mcp",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "chrome-devtools-mcp@latest",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ]
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/ChromeDevTools/chrome-devtools-mcp"
  },
  "title": "Chrome DevTools",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/ChromeDevTools/chrome-devtools-mcp"
}
