{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/zapier",
  "title": "Zapier",
  "description": "Automation platform for connecting apps and running no-code and AI-driven workflows.",
  "version": "latest",
  "websiteUrl": "https://help.zapier.com/hc/en-us/articles/36265392843917-Use-Zapier-MCP-with-your-client",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/zapier.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.zapier.com/api/mcp/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Required Zapier MCP API key header.",
          "value": "Bearer {zapier_api_key}",
          "isRequired": true,
          "isSecret": true,
          "variables": {
            "zapier_api_key": {
              "description": "Zapier MCP API key (required).",
              "isRequired": true,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
