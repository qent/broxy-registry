{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/postman",
  "title": "Postman",
  "description": "Postman MCP server for API platform workflows across collections, APIs, workspaces, and governance.",
  "version": "latest",
  "websiteUrl": "https://learning.postman.com/docs/developer/postman-api/postman-mcp-server/postman-mcp-remote-server",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/postman.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.postman.com/mcp",
      "oauth": {
        "type": "oauth",
        "allowDynamicRegistration": true
      }
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
