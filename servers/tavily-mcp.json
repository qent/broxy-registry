{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "description": "AI-oriented web search for up-to-date retrieval and research grounding.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ],
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/tavily-mcp.png"
    }
  ],
  "name": "io.qent.broxy/tavily-mcp",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "tavily-mcp@latest",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "environmentVariables": [
        {
          "description": "API key for Tavily search service",
          "isRequired": true,
          "isSecret": true,
          "name": "TAVILY_API_KEY"
        }
      ]
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/tavily-ai/tavily-mcp"
  },
  "title": "Tavily",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/tavily-ai/tavily-mcp"
}
