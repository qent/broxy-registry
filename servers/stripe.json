{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/stripe",
  "title": "Stripe MCP Server",
  "description": "Official Stripe remote MCP endpoint with OAuth support.",
  "version": "latest",
  "websiteUrl": "https://docs.stripe.com/mcp",
  "repository": {
    "source": "github",
    "url": "https://github.com/stripe/ai",
    "subfolder": "tools/modelcontextprotocol"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/stripe.png",
      "mimeType": "image/png",
      "sizes": [
        "64x64"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.stripe.com",
      "headers": [
        {
          "name": "Authorization",
          "description": "Optional bearer token (recommended: restricted Stripe API key).",
          "value": "Bearer {stripe_token}",
          "isRequired": false,
          "isSecret": true,
          "variables": {
            "stripe_token": {
              "description": "Stripe restricted API key or OAuth access token.",
              "isRequired": false,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
