{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/mcp-server-neon",
  "title": "Neon",
  "description": "Serverless Postgres platform for managed databases, branching, and developer workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/neondatabase-labs/mcp-server-neon",
  "repository": {
    "source": "github",
    "url": "https://github.com/neondatabase-labs/mcp-server-neon"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/mcp-server-neon.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.neon.tech/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Optional Neon API token in format: Bearer <token>.",
          "placeholder": "Bearer <neon_api_key>",
          "isSecret": true
        }
      ]
    }
  ]
}
