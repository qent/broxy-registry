{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "description": "Access Azure services and resources through MCP tools for cloud operations.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ],
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/azure.png"
    }
  ],
  "name": "io.qent.broxy/azure",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@azure/mcp@latest",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "server"
        },
        {
          "type": "positional",
          "value": "start"
        }
      ],
      "environmentVariables": [
        {
          "description": "Your Azure tenant ID",
          "isRequired": true,
          "isSecret": true,
          "name": "AZURE_TENANT_ID"
        },
        {
          "description": "Your Azure client ID for authentication",
          "isRequired": true,
          "isSecret": true,
          "name": "AZURE_CLIENT_ID"
        },
        {
          "description": "Your Azure client secret for authentication",
          "isRequired": true,
          "isSecret": true,
          "name": "AZURE_CLIENT_SECRET"
        }
      ]
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/microsoft/mcp",
    "subfolder": "servers/Azure.Mcp.Server"
  },
  "title": "Azure",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/Azure/azure-mcp"
}
