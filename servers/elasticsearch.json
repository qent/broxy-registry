{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/elasticsearch",
  "title": "Elastic",
  "description": "Elastic Agent Builder MCP endpoint for search and analytics workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://www.elastic.co/docs/explore-analyze/ai-features/agent-builder/mcp-server",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/elasticsearch.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "{KIBANA_URL}/api/agent_builder/mcp",
      "variables": {
        "KIBANA_URL": {
          "description": "Kibana host (with scheme), optionally including /s/{space_name} for non-default spaces.",
          "isRequired": true,
          "placeholder": "http"
        }
      },
      "headers": [
        {
          "name": "Authorization",
          "description": "Elastic API key header in format: ApiKey <key>.",
          "value": "ApiKey {API_KEY}",
          "isRequired": true,
          "isSecret": true,
          "variables": {
            "API_KEY": {
              "description": "Elastic API key with Agent Builder MCP access privileges.",
              "isRequired": true,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
