{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "description": "Live web research and answer generation powered by Perplexity Sonar.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ],
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/perplexity-ask.png"
    }
  ],
  "name": "io.qent.broxy/perplexity-ask",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@perplexity-ai/mcp-server",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "environmentVariables": [
        {
          "description": "Perplexity API key",
          "isRequired": true,
          "isSecret": true,
          "name": "PERPLEXITY_API_KEY"
        }
      ]
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/ppl-ai/modelcontextprotocol"
  },
  "title": "Perplexity",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/ppl-ai/modelcontextprotocol"
}
