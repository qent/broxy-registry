{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/github",
  "title": "GitHub",
  "description": "Developer platform for repositories, pull requests, issues, and team collaboration.",
  "version": "latest",
  "websiteUrl": "https://docs.github.com/en/copilot/how-tos/provide-context/use-mcp/extend-copilot-chat-with-mcp",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/github.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": [
        {
          "name": "Authorization",
          "description": "GitHub PAT for Copilot MCP endpoint.",
          "value": "Bearer {github_pat}",
          "isRequired": true,
          "isSecret": true,
          "variables": {
            "github_pat": {
              "description": "GitHub Personal Access Token.",
              "isRequired": true,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools",
        "resources"
      ]
    }
  }
}
