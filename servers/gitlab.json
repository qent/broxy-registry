{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.qent.broxy/gitlab",
  "title": "GitLab",
  "description": "MCP server for connecting AI clients to GitLab projects, issues, merge requests, and APIs.",
  "version": "latest",
  "websiteUrl": "https://docs.gitlab.com/user/gitlab_duo/model_context_protocol/mcp_server/",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/gitlab.png",
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://gitlab.com/api/v4/mcp",
      "oauth": {
        "type": "oauth",
        "allowDynamicRegistration": true
      }
    }
  ],
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  }
}
