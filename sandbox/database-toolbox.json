{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "io.qent.broxy/catalog": {
      "capabilities": [
        "tools"
      ]
    }
  },
  "description": "Unified database operations with connection pooling, authentication, and observability.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "128x128"
      ],
      "src": "https://raw.githubusercontent.com/qent/broxy-registry/main/icons/database-toolbox.png"
    }
  ],
  "name": "io.qent.broxy/database-toolbox",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@toolbox-sdk/server",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "named",
          "name": "--config",
          "valueHint": "tools_yaml_path",
          "description": "Path to Toolbox configuration YAML file.",
          "format": "filepath",
          "placeholder": "/path/to/tools.yaml",
          "isRequired": true
        }
      ]
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/googleapis/genai-toolbox"
  },
  "title": "Database Toolbox",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/googleapis/genai-toolbox"
}
