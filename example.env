# Common required inputs for broxy-registry runtime checks
# Replace placeholders with real credentials/endpoints where available.

# Required package environment variables
AZURE_CLIENT_ID=replace_me_azure_client_id
AZURE_CLIENT_SECRET=replace_me_azure_client_secret
AZURE_TENANT_ID=replace_me_azure_tenant_id
BRAVE_API_KEY=replace_me_brave_api_key
BROWSERBASE_API_KEY=replace_me_browserbase_api_key
BROWSERBASE_PROJECT_ID=replace_me_browserbase_project_id
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PASSWORD=replace_me_clickhouse_password
CLICKHOUSE_USER=default
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/postgres
ES_URL=http://localhost:9200
FIRECRAWL_API_KEY=replace_me_firecrawl_api_key
GEMINI_API_KEY=replace_me_gemini_api_key
GRAFANA_SERVICE_ACCOUNT_TOKEN=replace_me_grafana_service_account_token
GRAFANA_URL=http://localhost:3000
GRAPHLIT_ENVIRONMENT_ID=replace_me_graphlit_environment_id
GRAPHLIT_JWT_SECRET=replace_me_graphlit_jwt_secret
GRAPHLIT_ORGANIZATION_ID=replace_me_graphlit_organization_id
PERPLEXITY_API_KEY=replace_me_perplexity_api_key
SENTRY_ACCESS_TOKEN=replace_me_sentry_access_token
CHROMA_HOST=localhost
SONARQUBE_TOKEN=replace_me_sonarqube_token
SONARQUBE_ORG=replace_me_sonarqube_org
SONARQUBE_URL=https://sonarqube.example.com
TAVILY_API_KEY=replace_me_tavily_api_key

# Required package arguments
allowed_directory=/Users/dolf/Repos/broxy-registry
redis_url=redis://localhost:6379/0
tools_yaml_path=/Users/dolf/Repos/broxy-registry/artifacts/toolbox-tools.yaml

# Required remote header variables
box_client_id=replace_me_box_client_id
box_client_id_metadata_url=https://example.com/.well-known/oauth-client/box.json
github_pat=replace_me_github_pat
project_path=/Users/dolf/Repos/broxy-registry
slack_client_id=replace_me_slack_client_id
